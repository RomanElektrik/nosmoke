{
  "expo": {
    "name": "Бросить курить",
    "slug": "quit-smoke",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "quitsmoke",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.quitsmoke.client",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.quitsmoke.client"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-notifications",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F2F2F7",
          "dark": {
            "backgroundColor": "#0B0F14"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8190bbe8-96cc-4a73-a2d3-4a42bc159e1c"
      }
    },
    "owner": "romansuuz"
  }
}
